# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── PostgreSQL (option 1: Render DATABASE_URL) ────────────────────────────────
# On Render: link your PostgreSQL service and copy the Internal Database URL here.
# DATABASE_URL=postgres://user:password@host/dbname
# DB_SSL=false   # set to "false" to disable SSL when using the internal (private) URL

# ── PostgreSQL (option 2: individual vars for local dev) ─────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=chef_link_dev
# DB_SSL=true    # set to "true" if your database requires SSL (external cloud DBs)

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_strong_random_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_different_strong_random_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
